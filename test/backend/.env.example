# Database
DATABASE_URL="postgresql://quotefast:quotefast_dev@localhost:5432/quotefast"

# JWT — use long random strings in production (min 32 chars)
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-in-production-min-32-chars"

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# AWS (required for SQS email/PDF jobs)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
SQS_QUEUE_URL=""
