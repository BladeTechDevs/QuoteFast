{
  "name": "quotefast-workers",
  "version": "0.1.0",
  "description": "QuoteFast Lambda Workers",
  "private": true,
  "scripts": {
    "build": "tsc",
    "test": "jest --runInBand",
    "test:run": "jest --runInBand --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-ses": "^3.0.0",
    "@aws-sdk/client-sqs": "^3.0.0",
    "@prisma/client": "^5.10.0",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.136",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/pdfkit": "^0.13.4",
    "jest": "^29.7.0",
    "prisma": "^5.10.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node"
  }
}
